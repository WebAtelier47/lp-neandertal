---
const values = [
  { title: 'Sourcing local', description: 'Des forêts françaises gérées durablement, en direct avec les exploitants.' },
  { title: 'Séchage naturel', description: "Un bois correctement séché, stable et prêt à l'usage sans traitement chimique." },
  { title: 'Zéro additif', description: 'Aucun produit ajouté. La qualité vient du bois lui-même, pas d\'un traitement.' },
];
---

<section class="section about" id="nous-sommes" aria-labelledby="about__title">
  <div class="container about__container">

    <div class="block about__header">
      <p class="about__label">Qui nous sommes</p>
      <h2 class="about__title" id="about__title">
        Une conviction simple.<br />Le bois bien traité est un matériau noble.
      </h2>
      <p class="about__lead">
        Neandertal est né du refus du bois banal. Nous travaillons directement
        avec des exploitants forestiers locaux pour vous offrir des produits
        dont la qualité est constante, traçable et sans compromis.
      </p>
    </div>

    <div class="block about__values">
      {values.map(value => (
        <div class="about__value">
          <h3 class="about__value-title">{value.title}</h3>
          <p class="about__value-description">{value.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .about {
    padding-block: var(--space-section-lg);
    background-color: var(--color-bg-subtle);
  }

  .about__container {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-gap-lg);
  }

  @media (min-width: 768px) {
    .about__container {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  /* Block: header */
  .about__label {
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    letter-spacing: var(--label-tracking);
    text-transform: var(--label-transform);
    color: var(--color-accent-text);
    margin-bottom: var(--space-stack-md);
  }

  .about__title {
    font-family: var(--font-heading);
    font-size: var(--h2-size);
    line-height: var(--h2-leading);
    font-weight: var(--h2-weight);
    letter-spacing: var(--h2-tracking);
    color: var(--color-text);
    margin-bottom: var(--space-stack-md);
  }

  .about__lead {
    font-size: var(--lead-size);
    line-height: var(--lead-leading);
    color: var(--color-text-secondary);
    max-width: 44ch;
  }

  /* Block: values */
  .about__values {
    display: flex;
    flex-direction: column;
    gap: var(--space-gap-md);
  }

  .about__value {
    padding-block: var(--space-stack-md);
    border-top: var(--border-subtle);
  }

  .about__value-title {
    font-family: var(--font-heading);
    font-size: var(--h4-size);
    line-height: var(--h4-leading);
    font-weight: var(--h4-weight);
    color: var(--color-text);
    margin-bottom: var(--space-stack-xs);
  }

  .about__value-description {
    font-size: var(--text-base);
    line-height: var(--p-leading-normal);
    color: var(--color-text-secondary);
  }
</style>
