---
const year = new Date().getFullYear();

const links = [
  { label: 'Allume-feu',     href: '#allume-feu' },
  { label: 'Grillage',       href: '#grillage' },
  { label: 'Paillage',       href: '#paillage' },
  { label: 'Qui sommes-nous', href: '#nous-sommes' },
  { label: 'Contact',        href: '#contact' },
];
---

<footer class="footer">
  <div class="container footer__container">

    <div class="footer__block-brand">
      <a class="footer__logo" href="/">Neandertal</a>
      <p class="footer__tagline">Le bois comme on l'aime.</p>
    </div>

    <nav class="footer__block-nav" aria-label="Navigation pied de page">
      <ul class="footer__nav-list">
        {links.map(link => (
          <li><a class="footer__nav-link" href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-container">
      <p class="footer__copy">&copy; {year} Neandertal. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-muted);
    border-top: var(--border-subtle);
    padding-inline: var(--layout-gutter);
  }

  .footer__container {
    padding-block: var(--space-section);
    display: flex;
    flex-direction: column;
    gap: var(--space-gap-lg);
  }

  @media (min-width: 640px) {
    .footer__container {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  /* Block: brand */
  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--p-weight-normal);
    letter-spacing: var(--p-tracking-tight);
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-stack-sm);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  /* Block: nav */
  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-sm);
  }

  @media (min-width: 480px) {
    .footer__nav-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-inline-lg);
    }
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: var(--transition-colors);
  }
  .footer__nav-link:hover {
    color: var(--color-text);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: var(--border-subtle);
  }

  .footer__bottom-container {
    padding-block: var(--space-stack-md);
  }

  .footer__copy {
    font-size: var(--caption-size);
    color: var(--color-text-tertiary);
    letter-spacing: var(--caption-tracking);
  }
</style>
