---
interface Props {
  maxWidth?: 'default' | 'content' | 'narrow';
}
const { maxWidth = 'default' } = Astro.props;
---

<div class="container" data-width={maxWidth}>
  <slot />
</div>

<style>
  .container {
    margin-inline: auto;
    padding-inline: var(--layout-gutter);
    width: 100%;
  }
  .container[data-width="default"] { max-width: var(--layout-max); }
  .container[data-width="content"]  { max-width: var(--layout-content); }
  .container[data-width="narrow"]   { max-width: var(--layout-narrow); }
</style>
