---
interface Props {
  id: string;
  label: string;
  title: string;
  description: string;
  details: string[];
  reversed?: boolean;
  bgVariant?: 'default' | 'subtle' | 'muted';
}

const {
  id,
  label,
  title,
  description,
  details,
  reversed = false,
  bgVariant = 'default',
} = Astro.props;
---

<section class="product" id={id} data-reversed={reversed} data-bg={bgVariant} aria-labelledby={`${id}-title`}>
  <div class="product-inner">

    <div class="product-visual" aria-hidden="true">
      <div class="product-image-placeholder">
        <slot name="icon" />
      </div>
    </div>

    <div class="product-content">
      <p class="product-label">{label}</p>
      <h2 class="product-title" id={`${id}-title`}>{title}</h2>
      <p class="product-description">{description}</p>
      <ul class="product-details">
        {details.map(detail => (
          <li class="product-detail">
            <span class="product-detail-dot" aria-hidden="true"></span>
            {detail}
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .product {
    padding-block: var(--space-section);
    padding-inline: var(--layout-gutter);
  }
  .product[data-bg="subtle"] { background-color: var(--color-bg-subtle); }
  .product[data-bg="muted"]  { background-color: var(--color-bg-muted); }

  .product-inner {
    max-width: var(--layout-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-gap-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .product-inner {
      grid-template-columns: 1fr 1fr;
    }
    .product[data-reversed="true"] .product-visual {
      order: 2;
    }
    .product[data-reversed="true"] .product-content {
      order: 1;
    }
  }

  /* Visual */
  .product-image-placeholder {
    aspect-ratio: 1;
    background-color: var(--color-bg-muted);
    border-radius: var(--radius-lg);
    border: var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-tertiary);
  }
  .product[data-bg="subtle"] .product-image-placeholder,
  .product[data-bg="muted"]  .product-image-placeholder {
    background-color: var(--color-surface);
  }

  /* Content */
  .product-label {
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    letter-spacing: var(--label-tracking);
    text-transform: var(--label-transform);
    color: var(--color-accent-text);
    margin-bottom: var(--space-stack-md);
  }

  .product-title {
    font-family: var(--font-heading);
    font-size: var(--h2-size);
    line-height: var(--h2-leading);
    font-weight: var(--h2-weight);
    letter-spacing: var(--h2-tracking);
    color: var(--color-text);
    margin-bottom: var(--space-stack-md);
  }

  .product-description {
    font-size: var(--lead-size);
    line-height: var(--lead-leading);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-stack-lg);
    max-width: 44ch;
  }

  /* Details list */
  .product-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-sm);
  }

  .product-detail {
    display: flex;
    align-items: baseline;
    gap: var(--space-inline-sm);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .product-detail-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    translate: 0 -1px;
  }
</style>
