---
import Base from '../layouts/Base.astro';
---

<Base title="Design Tokens — Validation">
  <main class="page">

    <!-- Typographie -->
    <section class="section">
      <div class="container">
        <p class="label">Typographie</p>
        <h1 class="h1">Heading 1 — Premium sobre</h1>
        <h2 class="h2">Heading 2 — Hierarchie claire</h2>
        <h3 class="h3">Heading 3 — Structure nette</h3>
        <h4 class="h4">Heading 4 — Detail maitrise</h4>
        <p class="lead">Texte d'introduction — Un systeme de design tokenise, sobre et haut de gamme pour des landing pages Astro.</p>
        <p class="body">Texte courant — Les espacements genereux, la typographie soignee et les surfaces propres construisent une impression de qualite et de maitrise.</p>
        <p class="small">Petit texte — Details secondaires et mentions complementaires.</p>
        <p class="caption">Caption — Metadonnees et annotations discretes.</p>
      </div>
    </section>

    <!-- Couleurs -->
    <section class="section" data-variant="subtle">
      <div class="container">
        <p class="label">Couleurs</p>
        <h2 class="h3">Palette neutre</h2>
        <div class="color-grid">
          <div class="color-swatch" style="background: var(--p-color-neutral-0); border: var(--border-subtle);"><span>0</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-50);"><span>50</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-100);"><span>100</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-200);"><span>200</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-300);"><span>300</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-400);"><span>400</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-600); color: var(--color-text-inverse);"><span>600</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-800); color: var(--color-text-inverse);"><span>800</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-900); color: var(--color-text-inverse);"><span>900</span></div>
          <div class="color-swatch" style="background: var(--p-color-neutral-950); color: var(--color-text-inverse);"><span>950</span></div>
        </div>
        <h2 class="h3" style="margin-top: var(--space-stack-lg);">Accent</h2>
        <div class="color-grid">
          <div class="color-swatch" style="background: var(--p-color-accent-300);"><span>300</span></div>
          <div class="color-swatch" style="background: var(--p-color-accent-400); color: var(--color-text-inverse);"><span>400</span></div>
          <div class="color-swatch" style="background: var(--p-color-accent-500); color: var(--color-text-inverse);"><span>500</span></div>
          <div class="color-swatch" style="background: var(--p-color-accent-600); color: var(--color-text-inverse);"><span>600</span></div>
          <div class="color-swatch" style="background: var(--p-color-accent-700); color: var(--color-text-inverse);"><span>700</span></div>
        </div>
      </div>
    </section>

    <!-- Surfaces -->
    <section class="section">
      <div class="container">
        <p class="label">Surfaces et ombres</p>
        <div class="card-grid">
          <div class="card" data-shadow="xs">
            <p class="card-label">shadow-xs</p>
            <p class="small">Elevation minimale</p>
          </div>
          <div class="card" data-shadow="sm">
            <p class="card-label">shadow-sm</p>
            <p class="small">Elevation legere</p>
          </div>
          <div class="card" data-shadow="md">
            <p class="card-label">shadow-md</p>
            <p class="small">Elevation moyenne</p>
          </div>
          <div class="card" data-shadow="lg">
            <p class="card-label">shadow-lg</p>
            <p class="small">Elevation haute</p>
          </div>
          <div class="card" data-shadow="xl">
            <p class="card-label">shadow-xl</p>
            <p class="small">Elevation maximale</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Boutons -->
    <section class="section" data-variant="muted">
      <div class="container">
        <p class="label">Boutons</p>
        <div class="button-row">
          <button class="btn" data-variant="primary">Bouton principal</button>
          <button class="btn" data-variant="secondary">Bouton secondaire</button>
          <button class="btn" data-variant="ghost">Bouton ghost</button>
        </div>
      </div>
    </section>

    <!-- Espacements -->
    <section class="section">
      <div class="container">
        <p class="label">Espacements (echelle)</p>
        <div class="spacing-demo">
          <div class="spacing-bar" style="width: var(--p-space-1);"><span>1</span></div>
          <div class="spacing-bar" style="width: var(--p-space-2);"><span>2</span></div>
          <div class="spacing-bar" style="width: var(--p-space-3);"><span>3</span></div>
          <div class="spacing-bar" style="width: var(--p-space-4);"><span>4</span></div>
          <div class="spacing-bar" style="width: var(--p-space-6);"><span>6</span></div>
          <div class="spacing-bar" style="width: var(--p-space-8);"><span>8</span></div>
          <div class="spacing-bar" style="width: var(--p-space-10);"><span>10</span></div>
          <div class="spacing-bar" style="width: var(--p-space-12);"><span>12</span></div>
          <div class="spacing-bar" style="width: var(--p-space-16);"><span>16</span></div>
          <div class="spacing-bar" style="width: var(--p-space-20);"><span>20</span></div>
          <div class="spacing-bar" style="width: var(--p-space-24);"><span>24</span></div>
        </div>
      </div>
    </section>

  </main>
</Base>

<style>
  /* --- Page --- */
  .page {
    padding-block: var(--space-section);
  }

  /* --- Section --- */
  .section {
    padding-block: var(--space-section);
  }
  .section[data-variant="subtle"] {
    background-color: var(--color-bg-subtle);
  }
  .section[data-variant="muted"] {
    background-color: var(--color-bg-muted);
  }

  /* --- Container --- */
  .container {
    max-width: var(--layout-max);
    margin-inline: auto;
    padding-inline: var(--layout-gutter);
  }

  /* --- Typography demo --- */
  .label {
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    letter-spacing: var(--label-tracking);
    text-transform: var(--label-transform);
    color: var(--color-accent-text);
    margin-bottom: var(--space-stack-lg);
  }
  .h1 {
    font-family: var(--font-heading);
    font-size: var(--h1-size);
    line-height: var(--h1-leading);
    font-weight: var(--h1-weight);
    letter-spacing: var(--h1-tracking);
    margin-bottom: var(--space-stack-md);
  }
  .h2 {
    font-family: var(--font-heading);
    font-size: var(--h2-size);
    line-height: var(--h2-leading);
    font-weight: var(--h2-weight);
    letter-spacing: var(--h2-tracking);
    margin-bottom: var(--space-stack-md);
  }
  .h3 {
    font-family: var(--font-heading);
    font-size: var(--h3-size);
    line-height: var(--h3-leading);
    font-weight: var(--h3-weight);
    letter-spacing: var(--h3-tracking);
    margin-bottom: var(--space-stack-md);
  }
  .h4 {
    font-family: var(--font-heading);
    font-size: var(--h4-size);
    line-height: var(--h4-leading);
    font-weight: var(--h4-weight);
    letter-spacing: var(--h4-tracking);
    margin-bottom: var(--space-stack-md);
  }
  .lead {
    font-size: var(--lead-size);
    line-height: var(--lead-leading);
    font-weight: var(--lead-weight);
    color: var(--lead-color);
    margin-bottom: var(--space-stack-md);
  }
  .body {
    margin-bottom: var(--space-stack-md);
  }
  .small {
    font-size: var(--small-size);
    line-height: var(--small-leading);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-stack-sm);
  }
  .caption {
    font-size: var(--caption-size);
    line-height: var(--caption-leading);
    letter-spacing: var(--caption-tracking);
    color: var(--caption-color);
  }

  /* --- Color grid --- */
  .color-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-gap-sm);
  }
  .color-swatch {
    width: 5rem;
    height: 5rem;
    border-radius: var(--radius-md);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--space-inline-xs);
    font-size: var(--caption-size);
    font-weight: var(--p-weight-medium);
  }

  /* --- Card grid --- */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: var(--space-gap-md);
  }
  .card {
    background: var(--color-surface);
    border: var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-inset-md);
    transition: var(--transition-shadow), var(--transition-transform);
  }
  .card:hover {
    transform: translateY(-2px);
  }
  .card[data-shadow="xs"] { box-shadow: var(--shadow-xs); }
  .card[data-shadow="sm"] { box-shadow: var(--shadow-sm); }
  .card[data-shadow="md"] { box-shadow: var(--shadow-md); }
  .card[data-shadow="lg"] { box-shadow: var(--shadow-lg); }
  .card[data-shadow="xl"] { box-shadow: var(--shadow-xl); }
  .card[data-shadow="xs"]:hover { box-shadow: var(--shadow-sm); }
  .card[data-shadow="sm"]:hover { box-shadow: var(--shadow-md); }
  .card[data-shadow="md"]:hover { box-shadow: var(--shadow-lg); }
  .card[data-shadow="lg"]:hover { box-shadow: var(--shadow-xl); }
  .card[data-shadow="xl"]:hover { box-shadow: var(--shadow-xl); }
  .card-label {
    font-size: var(--label-size);
    font-weight: var(--label-weight);
    letter-spacing: var(--label-tracking);
    margin-bottom: var(--space-stack-xs);
  }

  /* --- Buttons --- */
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-gap-sm);
    align-items: center;
  }
  .btn {
    font-size: var(--button-size);
    font-weight: var(--button-weight);
    letter-spacing: var(--button-tracking);
    padding: var(--space-inline-sm) var(--space-inline-lg);
    border-radius: var(--radius-sm);
    transition: var(--transition-colors), var(--transition-shadow);
  }
  .btn[data-variant="primary"] {
    background-color: var(--color-accent);
    color: var(--color-text-inverse);
  }
  .btn[data-variant="primary"]:hover {
    background-color: var(--color-accent-hover);
    box-shadow: var(--shadow-sm);
  }
  .btn[data-variant="secondary"] {
    background-color: var(--color-surface);
    color: var(--color-text);
    border: var(--border-default);
  }
  .btn[data-variant="secondary"]:hover {
    background-color: var(--color-bg-subtle);
    box-shadow: var(--shadow-xs);
  }
  .btn[data-variant="ghost"] {
    background-color: transparent;
    color: var(--color-accent-text);
  }
  .btn[data-variant="ghost"]:hover {
    background-color: var(--color-bg-muted);
  }

  /* --- Spacing demo --- */
  .spacing-demo {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-xs);
  }
  .spacing-bar {
    height: 2rem;
    background-color: var(--color-accent-subtle);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-inline: var(--space-inline-xs);
    font-size: var(--caption-size);
    font-weight: var(--p-weight-medium);
    color: var(--color-accent-text);
    min-width: 2rem;
  }
</style>
