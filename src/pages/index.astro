---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductFeature from '../components/ProductFeature.astro';
import About from '../components/About.astro';
import Innovation from '../components/Innovation.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Neandertal — Bois d'allumage, de grillage et de paillage"
  description="Neandertal sélectionne et livre des bois d'allumage, de grillage et de paillage issus de forêts françaises gérées durablement."
>
  <Header />

  <main id="main-content">

    <Hero />

    <ProductFeature
      id="allume-feu"
      label="Produit"
      title="Allume-feu"
      description="Des allume-feux naturels, secs et efficaces. Pas de produit chimique, pas de fumée noire — juste la chaleur qui prend au premier essai."
      details={[
        'Bois d\'essence sèche, taux d\'humidité < 20 %',
        'Idéal pour cheminées, poêles et braseros',
        'Conditionné en fagots pratiques à stocker',
        'Sans additif, sans traitement',
      ]}
      bgVariant="default"
    >
      <svg slot="icon" viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true">
        <path d="M24 6C16 14 12 22 14 30C16 38 24 42 24 42C24 42 32 38 34 30C36 22 32 14 24 6Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M24 20C20 24 19 28 20 32C21 36 24 38 24 38C24 38 27 36 28 32C29 28 28 24 24 20Z" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.45"/>
      </svg>
    </ProductFeature>

    <ProductFeature
      id="grillage"
      label="Produit"
      title="Bois de grillage"
      description="Des essences soigneusement sélectionnées pour la cuisson. Un bois sec, dense et aromatique qui donne à vos grillades un caractère authentique."
      details={[
        'Essences sélectionnées pour leur pouvoir calorifique',
        'Arômes naturels, sans résine agressive',
        'Bûches calibrées, faciles à fendre et à disposer',
        'Braises longue durée pour une cuisson maîtrisée',
      ]}
      reversed={true}
      bgVariant="subtle"
    >
      <svg slot="icon" viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true">
        <rect x="8" y="30" width="32" height="4" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M12 30 L18 16 L24 28 L30 12 L36 30" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
      </svg>
    </ProductFeature>

    <ProductFeature
      id="paillage"
      label="Produit"
      title="Bois de paillage"
      description="Un paillage naturel qui protège vos sols, conserve l'humidité et se dégrade lentement pour nourrir votre terre. Idéal pour jardins et espaces verts."
      details={[
        'Protège les racines du gel et de la chaleur',
        'Réduit l\'arrosage en retenant l\'humidité',
        'Se dégrade lentement et enrichit le sol',
        'Issu de bois non traité, sans colorant',
      ]}
      bgVariant="default"
    >
      <svg slot="icon" viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true">
        <path d="M24 40 L24 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M24 28 C24 28 14 22 12 12 C18 12 24 20 24 20" stroke="currentColor" stroke-width="1.5" fill="none"/>
        <path d="M24 24 C24 24 34 18 36 8 C30 8 24 16 24 16" stroke="currentColor" stroke-width="1.5" fill="none"/>
      </svg>
    </ProductFeature>

    <About />

    <Innovation />

    <Contact />

  </main>

  <Footer />
</Base>
